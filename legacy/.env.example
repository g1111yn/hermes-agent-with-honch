# Core runtime
PROJECT_NAME=Hermes Persona PoC
CHARACTER_DIR=assets/character/default
DATA_DIR=data
DEFAULT_USER_ID=local-user

# Memory and runtime
SHORT_TERM_WINDOW=12
MEMORY_WRITE_THRESHOLD=2

# Honcho PoC service
HONCHO_ENABLED=true
HONCHO_URL=http://127.0.0.1:8787
HONCHO_TIMEOUT_SECONDS=5

# LLM provider
# Use "mock" for a self-contained smoke test.
# Use "openai_compatible" to point to the same upstream logic Hermes already uses.
LLM_PROVIDER=mock
LLM_MODEL=mock-persona-v1
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_TEMPERATURE=0.8

# TTS spike
ENABLE_TTS_SPIKE=false
TTS_VOICE=Tingting
TTS_OUTPUT_DIR=data/tts
