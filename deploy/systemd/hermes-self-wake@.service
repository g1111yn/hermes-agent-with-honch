[Unit]
Description=Hermes self-wake runner
After=network-online.target hermes-agent@%i.service
Wants=network-online.target

[Service]
Type=oneshot
User=%i
WorkingDirectory=/opt/hermes-persona
EnvironmentFile=/opt/hermes-persona/deploy/host/hermes-host.env
ExecStart=/opt/hermes-persona/runtime/hermes-agent/venv/bin/python /opt/hermes-persona/scripts/run_self_wake.py

