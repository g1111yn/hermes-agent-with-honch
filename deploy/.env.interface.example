WECHAT_GATEWAY_HOST=0.0.0.0
WECHAT_GATEWAY_PORT=8080
WECHAT_GATEWAY_TOKEN=change-me
WECHAT_BRIDGE_MODE=ipad
WECHAT_BRIDGE_NAME=gewechat
WECHAT_CHUNK_DELAY_SECONDS=0.9
WECHAT_GATEWAY_STATE_DIR=/opt/hermes-persona/server-state/wechat-gateway
WECHAT_GATEWAY_DEDUPE_TTL_SECONDS=300

# Concrete bridge driver: Gewechat / iPad-style HTTP bridge
WECHAT_BRIDGE_API_BASE=http://bridge-host:2531/v2/api
WECHAT_BRIDGE_APP_ID=
WECHAT_BRIDGE_TOKEN=
WECHAT_BRIDGE_CALLBACK_URL=https://your-domain.example/bridges/gewechat/callback
WECHAT_BRIDGE_AUTO_REGISTER_CALLBACK=false
