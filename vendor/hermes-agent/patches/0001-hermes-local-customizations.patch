+    role_block = deepcopy(hosts.get(host_key, {}))
+    for key in (
+        "recallMode",
+        "writeFrequency",
+        "sessionStrategy",
+        "sessionPeerPrefix",
+        "contextTokens",
+        "dialecticReasoningLevel",
+        "dialecticDynamic",
