+            "user": source_dir / "memories" / _ROLE_ASSET_FILENAMES["user"],
+            "memory": source_dir / "memories" / _ROLE_ASSET_FILENAMES["memory"],
+            "presence": source_dir / _ROLE_ASSET_FILENAMES["presence"],
+            "skills": source_dir / "skills",
+        }
+        for key, path in maybe.items():
