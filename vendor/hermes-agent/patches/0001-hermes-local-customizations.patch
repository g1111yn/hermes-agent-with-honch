+def _read_claude_desktop_oauth_credentials() -> Optional[Dict[str, Any]]:
+    """Read refreshable OAuth credentials from Claude Desktop's token cache.
+
+    Claude Desktop stores the official first-party login in
+    ``~/Library/Application Support/Claude/config.json`` under the encrypted
+    ``oauth:tokenCache`` key.  On macOS this blob uses Chromium/Electron's
+    safe-storage format (``v10`` prefix, AES-CBC, key from Keychain entry
+    ``Claude Safe Storage``).
+    """
+    if os.uname().sysname != "Darwin":
+        return None
+
+    config_path = Path.home() / "Library" / "Application Support" / "Claude" / "config.json"
+    if not config_path.exists():
+        return None
+
+    try:
+        payload = json.loads(config_path.read_text(encoding="utf-8"))
+    except (json.JSONDecodeError, OSError, IOError) as e:
+        logger.debug("Failed to read Claude desktop config.json: %s", e)
+        return None
+
+    encrypted_cache = payload.get("oauth:tokenCache")
+    if not isinstance(encrypted_cache, str) or not encrypted_cache.strip():
+        return None
+
+    secret = _read_claude_safe_storage_secret()
+    if not secret:
+        return None
+
+    decrypted = _decrypt_claude_desktop_token_cache(encrypted_cache, secret)
+    if not isinstance(decrypted, dict):
+        return None
+
+    for cache_key, entry in decrypted.items():
+        if not isinstance(entry, dict):
+            continue
+        access_token = str(entry.get("token") or "").strip()
+        refresh_token = str(entry.get("refreshToken") or "").strip()
+        expires_at = entry.get("expiresAt")
+        if not access_token:
+            continue
+        if "api.anthropic.com" not in str(cache_key):
+            continue
+        return {
+            "accessToken": access_token,
+            "refreshToken": refresh_token,
+            "expiresAt": expires_at or 0,
+            "source": "claude_desktop_token_cache",
+        }
+
     return None
 
 
+def _read_claude_safe_storage_secret() -> Optional[str]:
+    """Read Claude Desktop's safe-storage secret from macOS Keychain."""
+    import subprocess
+    import shutil
+
+    security_bin = shutil.which("security") or "/usr/bin/security"
+    try:
+        result = subprocess.run(
+            [security_bin, "find-generic-password", "-s", "Claude Safe Storage", "-w"],
+            check=True,
+            capture_output=True,
+            text=True,
+            timeout=30,
+        )
+    except Exception as e:
+        logger.debug("Failed to read Claude Safe Storage secret: %s", e)
+        return None
+
+    secret = (result.stdout or "").strip()
+    return secret or None
+
+
+def _decrypt_claude_desktop_token_cache(
+    encrypted_cache: str,
+    secret: str,
+) -> Optional[Dict[str, Any]]:
+    """Decrypt Claude Desktop's Chromium/Electron token cache."""
+    try:
+        from cryptography.hazmat.backends import default_backend
+        from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes
+    except Exception as e:
+        logger.debug("cryptography unavailable for Claude desktop token cache: %s", e)
+        return None
+
+    try:
+        raw = base64.b64decode(encrypted_cache)
+        if raw.startswith(b"v10"):
+            raw = raw[3:]
+        key = hashlib.pbkdf2_hmac("sha1", secret.encode(), b"saltysalt", 1003, dklen=16)
+        iv = b" " * 16
+        cipher = Cipher(algorithms.AES(key), modes.CBC(iv), backend=default_backend())
+        decryptor = cipher.decryptor()
+        plaintext = decryptor.update(raw) + decryptor.finalize()
+        pad_len = plaintext[-1]
+        if isinstance(pad_len, str):  # pragma: no cover - py2 style guard
+            pad_len = ord(pad_len)
+        plaintext = plaintext[:-pad_len]
+        payload = json.loads(plaintext.decode("utf-8"))
+    except Exception as e:
+        logger.debug("Failed to decrypt Claude desktop token cache: %s", e)
+        return None
+
+    return payload if isinstance(payload, dict) else None
+
