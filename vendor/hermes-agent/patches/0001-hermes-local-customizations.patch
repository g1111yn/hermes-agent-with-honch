+        pass
+
+    save_role_manifest(name, manifest)
+    return profile_dir, manifest, created
+
+
+def reset_role_profile(name: str) -> tuple[Path, dict]:
+    """Rebuild a role profile to a clean local baseline and advance Honcho generation."""
+    validate_profile_name(name)
+    if name == "default":
+        raise ValueError("The default profile cannot be managed as a role.")
+
+    prior_manifest = load_role_manifest(name)
+    profile_dir, existing_manifest, created = prepare_role_profile(name)
+    if not created:
+        try:
+            _stop_gateway_process(profile_dir)
+        except Exception:
+            pass
+
+    _remove_path(profile_dir / "skills")
+    _remove_path(profile_dir / "sessions")
+    _remove_path(profile_dir / "memories")
+    _remove_path(profile_dir / "logs")
+    _remove_path(profile_dir / ".skills_prompt_snapshot.json")
+
+    for rel in _ROLE_RUNTIME_GLOBS:
+        _remove_path(profile_dir / rel)
+
+    _ensure_role_files(profile_dir)
+
+    if prior_manifest is None:
+        generation = 1
+    else:
+        generation = prior_manifest.get("generation", 1)
+        try:
+            generation = int(generation) + 1
+        except (TypeError, ValueError):
+            generation = 1
+
+    manifest = build_role_manifest(
+        name,
+        generation=max(1, generation),
+        last_reset_at=_role_now(),
+    )
+
+    try:
+        from plugins.memory.honcho.cli import ensure_role_honcho_config
+
+        honcho_state = ensure_role_honcho_config(name, generation=manifest["generation"])
+        manifest.update({
+            "honcho_host": honcho_state["host"],
+            "honcho_workspace": honcho_state["workspace"],
+            "honcho_ai_peer": honcho_state["ai_peer"],
+            "honcho_user_peer": honcho_state["user_peer"],
+        })
+    except Exception:
+        pass
+
+    save_role_manifest(name, manifest)
+    return profile_dir, manifest
+
+
+def inspect_role_profile(name: str) -> dict:
+    """Return the current isolation state for a role-backed profile."""
+    validate_profile_name(name)
+    if name == "default":
+        raise ValueError("The default profile cannot be managed as a role.")
+
+    profile_dir = get_profile_dir(name)
+    exists = profile_dir.is_dir()
+    manifest = load_role_manifest(name)
+    if not manifest:
+        manifest = build_role_manifest(name)
+
+    return {
+        "role_id": name,
+        "profile_exists": exists,
+        "profile_dir": str(profile_dir),
+        "manifest_path": str(get_role_manifest_path(name)),
+        "presence_config_path": str(profile_dir / "presence-config.json"),
+        "manifest": manifest,
+        "has_soul": (profile_dir / "SOUL.md").exists(),
+        "has_user_memory": (profile_dir / "memories" / "USER.md").exists(),
+        "has_long_memory": (profile_dir / "memories" / "MEMORY.md").exists(),
+        "has_presence_config": (profile_dir / "presence-config.json").exists(),
+        "skills_count": _count_skills(profile_dir) if exists else 0,
+        "session_files": len(list((profile_dir / "sessions").glob("*"))) if (profile_dir / "sessions").exists() else 0,
+        "skills_snapshot": (profile_dir / ".skills_prompt_snapshot.json").exists(),
+        "gateway_running": _check_gateway_running(profile_dir) if exists else False,
+    }
