+    memory_text = asset_paths["memory"].read_text(encoding="utf-8") if "memory" in asset_paths else ""
+
+    if "soul" in asset_paths:
+        target = profile_dir / "SOUL.md"
+        target.write_text(soul_text, encoding="utf-8")
+        written["soul"] = str(target)
+
+    if "user" in asset_paths:
+        target = profile_dir / "memories" / "USER.md"
+        target.write_text(user_text, encoding="utf-8")
+        written["user"] = str(target)
+
+    if "memory" in asset_paths:
+        target = profile_dir / "memories" / "MEMORY.md"
+        target.write_text(memory_text, encoding="utf-8")
+        written["memory"] = str(target)
+
+    from agent.presence import build_default_presence_config
+
+    derived_presence = _derive_presence_config_from_assets(
