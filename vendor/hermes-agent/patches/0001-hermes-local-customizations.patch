+                "expiresAt": int(time.time() * 1000) + 3600_000,
+            }
+        }
+        plaintext = json.dumps(token_payload).encode("utf-8")
+        pad = 16 - (len(plaintext) % 16)
+        plaintext += bytes([pad]) * pad
+        key = hashlib.pbkdf2_hmac("sha1", secret.encode(), b"saltysalt", 1003, dklen=16)
+        iv = b" " * 16
