+def _load_presence_style_overrides(text: str) -> Dict[str, Any]:
+    """Best-effort profile-scoped TTS style hints from presence memory."""
+    try:
+        from agent.presence import PresenceManager
+
+        manager = PresenceManager()
+        overrides = manager.get_tts_overrides(text)
+        return overrides if isinstance(overrides, dict) else {}
+    except Exception as exc:
+        logger.debug("presence-derived TTS overrides unavailable: %s", exc)
+        return {}
+
+
+def _merge_tts_config_overrides(tts_config: Dict[str, Any], style_overrides: Optional[Dict[str, Any]]) -> Dict[str, Any]:
+    """Apply transient style overrides without mutating stored config."""
+    merged = copy.deepcopy(tts_config or {})
+    if not style_overrides:
+        return merged
+
+    speed = style_overrides.get("speed")
+    if isinstance(speed, (int, float)):
+        merged["speed"] = float(speed)
+
+    provider_overrides = style_overrides.get("provider_overrides") or {}
+    if isinstance(provider_overrides, dict):
+        for provider_name, provider_updates in provider_overrides.items():
+            if not isinstance(provider_updates, dict):
+                continue
+            current = merged.get(provider_name)
+            if not isinstance(current, dict):
