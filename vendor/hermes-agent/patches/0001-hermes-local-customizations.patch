+def apply_role_assets(
+    name: str,
+    *,
+    source_dir: Path | None = None,
+    soul_path: Path | None = None,
+    user_path: Path | None = None,
+    memory_path: Path | None = None,
+    presence_path: Path | None = None,
+    skills_dir: Path | None = None,
