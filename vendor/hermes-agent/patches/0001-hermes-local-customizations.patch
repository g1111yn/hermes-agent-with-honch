+    def fallback(cls, reason: str, *, topics: list[str] | None = None) -> "HermesDialecticAnalysis":
+        return cls(
+            need_state="steady",
+            emotional_tone="neutral",
+            initiative_hint="Use the available memory softly; do not over-assert.",
+            topic_suggestions=topics or [],
+            confidence=0.15,
+            reasoning_summary=reason,
+        )
+
+    @classmethod
+    def from_payload(
+        cls,
+        payload: dict[str, Any] | None,
+        *,
+        fallback_reason: str = "",
+        fallback_topics: list[str] | None = None,
+    ) -> "HermesDialecticAnalysis":
+        if not isinstance(payload, dict):
+            return cls.fallback(fallback_reason or "Invalid dialectic payload.", topics=fallback_topics)
+
+        topics = payload.get("topic_suggestions", [])
+        if isinstance(topics, str):
+            topics = [item.strip() for item in topics.split(";") if item.strip()]
+        elif isinstance(topics, list):
+            topics = [str(item).strip() for item in topics if str(item).strip()]
+        else:
+            topics = []
+
+        try:
+            confidence = float(payload.get("confidence", 0.0))
+        except (TypeError, ValueError):
+            confidence = 0.0
+
+        analysis = cls(
+            need_state=str(payload.get("need_state") or "steady").strip() or "steady",
+            emotional_tone=str(payload.get("emotional_tone") or "neutral").strip() or "neutral",
+            initiative_hint=str(payload.get("initiative_hint") or "Use remembered context gently and do not force a topic.").strip(),
+            topic_suggestions=topics[:3],
+            confidence=max(0.0, min(confidence, 1.0)),
+            reasoning_summary=str(payload.get("reasoning_summary") or fallback_reason or "").strip(),
+        )
+        if not analysis.reasoning_summary and fallback_reason:
+            analysis.reasoning_summary = fallback_reason
+        if not analysis.topic_suggestions and fallback_topics:
