+        return "\n".join(lines)
+
+    def to_tool_result(self) -> str:
+        parts = [
+            f"need_state: {self.need_state}",
+            f"emotional_tone: {self.emotional_tone}",
+            f"initiative_hint: {self.initiative_hint}",
+        ]
+        if self.topic_suggestions:
+            parts.append("topic_suggestions: " + "; ".join(self.topic_suggestions[:3]))
+        parts.append(f"confidence: {self.confidence:.2f}")
+        if self.reasoning_summary:
+            parts.append(f"reasoning_summary: {self.reasoning_summary}")
+        return "\n".join(parts)
+
